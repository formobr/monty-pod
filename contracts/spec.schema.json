{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "monty-pod/contracts/spec.schema.json",
  "title": "RenderSpec — the planner→pod render instruction (data, never code)",
  "description": "Everything the pod needs to render ONE output pass. Invariants: every number is a number (no 'auto'); no threshold carries meaning (the planner already applied it — the pod is told WHAT, never WHY); no prompts, no scores, no rationale. Every media path referenced anywhere (timeline src, overlays clip/track) MUST equal an inputs[].id.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "spec_version",
    "job_id",
    "slug",
    "mode",
    "inputs",
    "timeline",
    "encode",
    "outputs"
  ],
  "properties": {
    "spec_version": {
      "const": 5
    },
    "job_id": {
      "type": "string",
      "minLength": 1
    },
    "slug": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "enum": [
        "preview",
        "final"
      ]
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/input"
      }
    },
    "timeline": {
      "$ref": "#/$defs/timeline"
    },
    "motion": {
      "$ref": "#/$defs/motion"
    },
    "overlays": {
      "$ref": "#/$defs/overlays"
    },
    "encode": {
      "$ref": "#/$defs/encode"
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/output"
      }
    },
    "base_voice_rescued": {
      "type": "boolean"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "mode": {
            "const": "preview"
          }
        },
        "required": [
          "mode"
        ]
      },
      "then": {
        "not": {
          "required": [
            "overlays"
          ]
        }
      }
    }
  ],
  "$defs": {
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "sha256",
        "url"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "enum": [
            "video",
            "audio",
            "image",
            "font",
            "code"
          ]
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "url": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "timeline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fps",
        "width",
        "height",
        "segments"
      ],
      "properties": {
        "fps": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "width": {
          "type": "integer",
          "minimum": 2
        },
        "height": {
          "type": "integer",
          "minimum": 2
        },
        "segments": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/segment"
          }
        }
      }
    },
    "segment": {
      "description": "One kept span, SOURCE time, seconds, frame-snapped by the planner at timeline.fps. speed is a per-segment atempo/setpts factor.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "src",
        "in",
        "out",
        "speed"
      ],
      "properties": {
        "src": {
          "type": "string",
          "minLength": 1
        },
        "in": {
          "type": "number",
          "minimum": 0
        },
        "out": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "speed": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "motion": {
      "description": "Camera-motion keyframes the planner computed; the pod only interpolates rects and applies the crop/zoom. t = seconds from the rendered segment's start on the OUTPUT clock (post-speed). rect = [x, y, w, h] normalized fractions of the source frame.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "segments"
      ],
      "properties": {
        "segments": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "seg",
              "interp",
              "keyframes"
            ],
            "properties": {
              "seg": {
                "type": "integer",
                "minimum": 0
              },
              "interp": {
                "enum": [
                  "linear",
                  "ease_in",
                  "ease_out",
                  "ease_in_out"
                ]
              },
              "keyframes": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "t",
                    "rect"
                  ],
                  "properties": {
                    "t": {
                      "type": "number",
                      "minimum": 0
                    },
                    "rect": {
                      "type": "array",
                      "minItems": 4,
                      "maxItems": 4,
                      "items": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 1
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "overlays": {
      "description": "FINAL tier only (the preview tier composites overlays client-side). The RESOLVED render fields of the plan — planning metadata never crosses this seam.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "broll_final": {
          "$ref": "#/$defs/broll_final"
        },
        "motion_plan": {
          "$ref": "#/$defs/motion_plan"
        },
        "music": {
          "$ref": "#/$defs/music"
        },
        "cover": {
          "$ref": "#/$defs/cover"
        },
        "trims": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/trim"
          }
        },
        "sfx": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sfx"
          }
        },
        "finalize": {
          "$ref": "#/$defs/finalize"
        }
      }
    },
    "sfx": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sound",
        "at",
        "gain"
      ],
      "properties": {
        "sound": {
          "type": "string",
          "minLength": 1
        },
        "at": {
          "type": "number",
          "minimum": 0
        },
        "gain": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 2
        }
      }
    },
    "broll_final": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "broll"
      ],
      "properties": {
        "broll": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/broll_clip"
          }
        }
      }
    },
    "broll_clip": {
      "description": "clip references an inputs[].id. start/dur on the final output clock; in = source offset inside the cutaway asset.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "clip",
        "start",
        "preset"
      ],
      "properties": {
        "clip": {
          "type": "string",
          "minLength": 1
        },
        "start": {
          "type": "number",
          "minimum": 0
        },
        "preset": {
          "type": "string",
          "minLength": 1
        },
        "dur": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "in": {
          "type": "number",
          "minimum": 0
        },
        "scale": {
          "type": "string"
        },
        "amount": {
          "type": "number"
        },
        "accent": {
          "type": "boolean"
        },
        "transition_in": {
          "$ref": "#/$defs/transition"
        },
        "transition_out": {
          "$ref": "#/$defs/transition"
        }
      }
    },
    "transition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "edge",
        "dur"
      ],
      "properties": {
        "kind": {
          "enum": [
            "slide_wipe",
            "push",
            "dissolve"
          ]
        },
        "edge": {
          "enum": [
            "entry",
            "return"
          ]
        },
        "direction": {
          "enum": [
            "left",
            "right",
            "up",
            "down"
          ]
        },
        "dur": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "dissolve"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "not": {
              "required": [
                "direction"
              ]
            }
          },
          "else": {
            "required": [
              "direction"
            ]
          }
        }
      ]
    },
    "motion_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sections"
      ],
      "properties": {
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "comp",
              "start",
              "props"
            ],
            "properties": {
              "comp": {
                "type": "string",
                "minLength": 1
              },
              "start": {
                "type": "number",
                "minimum": 0
              },
              "props": {
                "type": "object"
              },
              "glass": {
                "type": "boolean"
              }
            }
          }
        },
        "captions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "centerY": {
              "type": "number"
            },
            "accent": {
              "type": "string"
            },
            "style": {
              "enum": [
                "oneword",
                "phrase",
                "phrase_jump"
              ]
            },
            "hot": {
              "type": "array",
              "items": {
                "type": "number"
              }
            },
            "words": {
              "description": "Fully resolved subtitle events on the final clock (the brain bakes the transcript; the pod has no ASR/brand). hot = lit in the accent colour.",
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "text",
                  "start",
                  "end"
                ],
                "properties": {
                  "text": {
                    "type": "string",
                    "minLength": 1
                  },
                  "start": {
                    "type": "number",
                    "minimum": 0
                  },
                  "end": {
                    "type": "number",
                    "minimum": 0
                  },
                  "hot": {
                    "type": "boolean"
                  }
                }
              }
            },
            "font": {
              "description": "an inputs[].id of the caption TTF (family the ASS style names).",
              "type": "string"
            }
          }
        },
        "brand": {
          "description": "Brand design for the agnostic Remotion bundle. tokens = brand_tokens.resolve; fonts = mograph_fonts.resolve. Role font files ride as inputs id 'mograph/public/<file>'; the pod stages them into the bundle public/ before render.",
          "type": "object",
          "additionalProperties": false,
          "required": [
            "tokens",
            "fonts"
          ],
          "properties": {
            "tokens": {
              "type": "object"
            },
            "fonts": {
              "type": "object"
            }
          }
        },
        "bundle": {
          "description": "Presigned GET for a tar of the Remotion project (src + node_modules + render_batch.mjs) plus its sha256 — the integrity check AND the pod's content-hash cache key. REQUIRED whenever sections is non-empty: the image bakes no bundle, so a section without one cannot render.",
          "type": "object",
          "additionalProperties": false,
          "required": [
            "url",
            "sha256"
          ],
          "properties": {
            "url": {
              "type": "string",
              "minLength": 1
            },
            "sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "size": {
              "type": "integer",
              "exclusiveMinimum": 0
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "sections": {
                "minItems": 1
              }
            },
            "required": [
              "sections"
            ]
          },
          "then": {
            "required": [
              "bundle"
            ]
          }
        }
      ]
    },
    "music": {
      "description": "track references an inputs[].id. gain is the linear mix multiplier under the voice — the pod has no brand profile, the number crosses the seam.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "track",
        "gain"
      ],
      "properties": {
        "track": {
          "type": "string",
          "minLength": 1
        },
        "start": {
          "type": "number",
          "minimum": 0
        },
        "gain": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 2
        }
      }
    },
    "cover": {
      "description": "frame_at is a NUMBER (seconds, final clock) — never 'auto'; the planner resolves the face-pick before writing the spec.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "frame_at",
        "headline"
      ],
      "properties": {
        "frame_at": {
          "type": "number",
          "minimum": 0
        },
        "headline": {
          "type": "object",
          "required": [
            "lines"
          ],
          "properties": {
            "lines": {
              "type": "array"
            },
            "pos": {
              "type": "string"
            },
            "y": {
              "type": "number"
            },
            "size": {
              "type": "number"
            },
            "box": {
              "type": "boolean"
            }
          }
        },
        "logo": {
          "type": "object"
        },
        "elements": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "colors": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          }
        },
        "font": {
          "type": "string"
        },
        "display_weight": {
          "type": "integer"
        }
      }
    },
    "trim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "a",
        "b"
      ],
      "properties": {
        "a": {
          "type": "number",
          "minimum": 0
        },
        "b": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "encode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "video",
        "preset",
        "cq",
        "pix_fmt",
        "audio",
        "audio_bitrate"
      ],
      "properties": {
        "video": {
          "enum": [
            "h264_nvenc",
            "libx264"
          ]
        },
        "preset": {
          "type": "string",
          "minLength": 1
        },
        "cq": {
          "type": "integer",
          "minimum": 0,
          "maximum": 51
        },
        "pix_fmt": {
          "enum": [
            "yuv420p"
          ]
        },
        "audio": {
          "enum": [
            "aac"
          ]
        },
        "audio_bitrate": {
          "type": "string",
          "pattern": "^[0-9]+k$"
        }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "put_url"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "enum": [
            "proxy",
            "master",
            "cache",
            "cover",
            "presync"
          ]
        },
        "put_url": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "accent": {
      "description": "One resolved frame-accent. The Director decided WHICH treatment fires WHERE and HOW HARD; the anchor phrase, the score and the reasoning that produced it never cross. `at` is on the FINAL output clock.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "at",
        "intensity"
      ],
      "properties": {
        "kind": {
          "enum": [
            "camera_shake",
            "grain",
            "zoom_punch",
            "glitch",
            "zoom_blur",
            "rgb_split",
            "pixelate"
          ]
        },
        "at": {
          "type": "number",
          "minimum": 0
        },
        "intensity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "logo": {
      "description": "The persistent corner logo over the BODY. `asset` is an inputs[].id of the logo PNG — the pod holds no brand profile. `cover_hold` is the length of the cover end-card tail the logo must not cover (the end-card carries its own logo).",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asset",
        "corner",
        "width",
        "opacity",
        "margin",
        "cover_hold"
      ],
      "properties": {
        "asset": {
          "type": "string",
          "minLength": 1
        },
        "corner": {
          "enum": [
            "tl",
            "tr",
            "bl",
            "br"
          ]
        },
        "width": {
          "type": "integer",
          "exclusiveMinimum": 0
        },
        "opacity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "margin": {
          "type": "integer",
          "minimum": 0
        },
        "cover_hold": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "watermark": {
      "description": "The animated brand watermark. `sting`/`idle` are inputs[].id of the two alpha .webm clips; the chime is the sting's own audio. `x`/`y` are NUMBERS in pixels (pass both or neither) — never an ffmpeg expression, which would be a filtergraph fragment crossing the seam.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sting",
        "idle",
        "width",
        "margin",
        "position"
      ],
      "properties": {
        "sting": {
          "type": "string",
          "minLength": 1
        },
        "idle": {
          "type": "string",
          "minLength": 1
        },
        "width": {
          "type": "integer",
          "exclusiveMinimum": 0
        },
        "margin": {
          "type": "integer",
          "minimum": 0
        },
        "position": {
          "enum": [
            "bottom-center",
            "bottom-right",
            "bottom-left",
            "top-center",
            "top-right",
            "top-left",
            "center"
          ]
        },
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "delay": {
          "type": "number",
          "minimum": 0
        },
        "chime": {
          "type": "boolean"
        },
        "chime_volume": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 2
        }
      },
      "dependentRequired": {
        "x": [
          "y"
        ],
        "y": [
          "x"
        ]
      }
    },
    "loudnorm": {
      "description": "Delivery loudness. `attenuate_only` is the PLANNER's verdict that the source clipped hot (it read a clipping sidecar the pod has never seen) — the pod applies it, it does not re-decide it.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "i",
        "tp",
        "lra"
      ],
      "properties": {
        "i": {
          "type": "number"
        },
        "tp": {
          "type": "number"
        },
        "lra": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "attenuate_only": {
          "type": "boolean"
        }
      }
    },
    "finalize": {
      "description": "The delivery tail applied AFTER the composite: frame accents, body logo, animated watermark, delivery loudness — in that order. Every sub-block is independently optional: a partner deliverable drops `logo`/`watermark` by OMISSION, never by a flag the pod interprets.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "accents": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/accent"
          }
        },
        "logo": {
          "$ref": "#/$defs/logo"
        },
        "watermark": {
          "$ref": "#/$defs/watermark"
        },
        "loudnorm": {
          "$ref": "#/$defs/loudnorm"
        }
      }
    }
  }
}
